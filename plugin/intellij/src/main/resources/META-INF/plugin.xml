<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
  <id>com.github.jshwi.docsig</id>
  <name>Docsig</name>
  <vendor url="https://github.com/jshwi/docsig">Stephen Whitlock</vendor>
  <resource-bundle>messages.DocsigBundle</resource-bundle>
  <depends>com.intellij.modules.platform</depends>
  <depends>com.intellij.modules.python</depends>
  <extensions defaultExtensionNs="com.intellij">
    <localInspection
      language="Python"
      implementationClass="com.github.jshwi.docsig.inspection.DocsigInspection"
      key="inspection.key.name"
      groupKey="inspection.group.name"
      enabledByDefault="true"/>
    <applicationConfigurable
      id="docsig.settings"
      key="configurable.display.name"
      instance="com.github.jshwi.docsig.ui.DocsigConfigurable"/>
    <notificationGroup
      id="Docsig"
      displayType="BALLOON"
      isLogByDefault="true" bundle="messages.DocsigBundle"
      key="notification.key.name"/>
  </extensions>
  <applicationListeners>
    <listener
      class="com.github.jshwi.docsig.listener.DocsigSaveListener"
      topic="com.intellij.openapi.fileEditor.FileDocumentManagerListener"/>
  </applicationListeners>
</idea-plugin>
