{
  "activationEvents": [
    "onLanguage:python"
  ],
  "bugs": "https://github.com/jshwi/docsig/issues",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "contributes": {
    "configuration": {
      "properties": {
        "docsig.checkDunders": {
          "default": false,
          "description": "Check dunder methods.",
          "type": "boolean"
        },
        "docsig.checkNested": {
          "default": false,
          "description": "Check nested functions and classes.",
          "type": "boolean"
        },
        "docsig.checkOverridden": {
          "default": false,
          "description": "Check overridden methods.",
          "type": "boolean"
        },
        "docsig.checkPropertyReturns": {
          "default": false,
          "description": "Check property return values.",
          "type": "boolean"
        },
        "docsig.checkProtected": {
          "default": false,
          "description": "Check protected functions and classes.",
          "type": "boolean"
        },
        "docsig.checkProtectedClassMethods": {
          "default": false,
          "description": "Check public methods belonging to protected classes.",
          "type": "boolean"
        },
        "docsig.classCheckMode": {
          "default": "None",
          "description": "Check class docstrings, __init__ methods, or neither.",
          "enum": [
            "None",
            "Check class",
            "Check class constructor"
          ],
          "enumDescriptions": [
            "Do not check class docstrings or constructors.",
            "Check class docstrings.",
            "Check class constructor (__init__) methods."
          ],
          "type": "string"
        },
        "docsig.disable": {
          "default": [],
          "description": "Comma separated list of rules to disable.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "docsig.exclude": {
          "default": "",
          "description": "Regular expression of files or dirs to exclude from checks.",
          "type": "string"
        },
        "docsig.excludes": {
          "default": [],
          "description": "Path glob patterns to exclude from checks.",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "docsig.ignoreArgs": {
          "default": false,
          "description": "Ignore args prefixed with an asterisk.",
          "type": "boolean"
        },
        "docsig.ignoreKwargs": {
          "default": false,
          "description": "Ignore kwargs prefixed with two asterisks.",
          "type": "boolean"
        },
        "docsig.ignoreNoParams": {
          "default": false,
          "description": "Ignore docstrings where parameters are not documented.",
          "type": "boolean"
        },
        "docsig.includeIgnored": {
          "default": false,
          "description": "Check files even if they match a gitignore pattern.",
          "type": "boolean"
        },
        "docsig.target": {
          "default": [],
          "description": "Comma separated list of rules to target.",
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "title": "Docsig"
    }
  },
  "description": "Check signature params for proper documentation",
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "26.x",
    "@types/sinon": "^22.0.0",
    "@types/vscode": "^1.125.0",
    "@vscode/test-cli": "^0.0.15",
    "@vscode/test-electron": "^3.0.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-check-file": "^3.3.1",
    "prettier": "^3.9.4",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "displayName": "Docsig",
  "engines": {
    "vscode": "^1.125.0"
  },
  "extensionDependencies": [
    "ms-python.python"
  ],
  "galleryBanner": {
    "color": "#093d65",
    "theme": "dark"
  },
  "homepage": "https://github.com/jshwi/docsig",
  "icon": "media/icon.png",
  "keywords": [
    "python",
    "docstring",
    "lint",
    "docsig"
  ],
  "license": "MIT",
  "main": "./out/main/extension.js",
  "name": "docsig",
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5"
  },
  "publisher": "jshwi",
  "qna": "https://github.com/jshwi/docsig/issues",
  "repository": {
    "directory": "plugin/vscode",
    "type": "git",
    "url": "https://github.com/jshwi/docsig.git"
  },
  "scripts": {},
  "version": "1.0.0"
}
