{
  "compilerOptions": {
    "lib": [
      "ES2022"
    ],
    "module": "Node16",
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUnusedParameters": true,
    "outDir": "out",
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022",
    "types": [
      "node",
      "mocha"
    ]
  }
}
